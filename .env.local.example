# Get a free token at https://account.mapbox.com/access-tokens/
# Copy this file to .env.local and fill in your token, then restart `npm run dev`.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Optional — powers the website→billboard flow on the landing page.
# Without it, Peel still works: it builds a heuristic brand brief from
# the scraped site and renders a brand-matched SVG billboard creative.
# With it, the brief is written by a model and the creative is image-generated.
# OPENAI_API_KEY=sk-...
# OPENAI_BRIEF_MODEL=gpt-4o-mini        # model for the structured brief (default)
# OPENAI_IMAGE_MODEL_LIVE=gpt-image-1   # fast model for live creatives (default)
# OPENAI_IMAGE_QUALITY_LIVE=low         # quality for live creatives — favour speed (default)
# OPENAI_IMAGE_MODEL_CACHE=gpt-image-2  # slow, high-quality model for the precomputed cache
# OPENAI_IMAGE_MODEL=gpt-image-1        # legacy fallback for OPENAI_IMAGE_MODEL_LIVE
#
# Precompute a brief + high-quality creative for a site so it loads instantly:
#   node scripts/build-brief-cache.mjs getfluent.tech
# Writes data/brief-cache/<host>.json and public/brief-cache/<host>.png.

# Powers the photoreal "see it on the street" preview on the map: we pull a
# real Google Street View still at each sign and warp the creative onto it.
# Enable the "Street View Static API" for the key in Google Cloud Console.
# Get one at https://console.cloud.google.com/google/maps-apis/credentials
# GOOGLE_MAPS_API_KEY=AIza...

# Run `npx orangeslice@latest` to authenticate — key is saved automatically.
# Powers the live Outbound Queue: ICP company search, enrichment, decision-maker
# discovery, and AI-drafted pitches. Without it the queue shows a staged preview.
ORANGESLICE_API_KEY=osk_...

# Fiber AI — contact (work email) reveal for the matched decision-makers in the
# Outbound Queue. Required alongside ORANGESLICE_API_KEY for live outbound.
# FIBER_API_KEY=...

# Optional — /vision billboard detection via NVIDIA NIM Grounding DINO.
# Get a free key at https://build.nvidia.com (search "grounding-dino").
# Without it, /vision still works: it falls back to the GPT-4o billboard box.
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_GDINO_URL=https://ai.api.nvidia.com/v1/cv/nvidia/grounding-dino  # override if needed

# Convex local development values are generated into .env.local by:
#   npm run convex:dev:once
# For cloud/CI deployment, create a deploy key in the Convex dashboard and set
# CONVEX_DEPLOY_KEY in the hosting provider, then run:
#   npm run convex:deploy
# NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
# CONVEX_DEPLOYMENT=dev:your-deployment
# CONVEX_DEPLOY_KEY=prod:...
