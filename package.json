{
  "name": "peel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "dev:clean": "node scripts/dev-server.mjs --clean",
    "convex:dev": "convex dev",
    "convex:dev:once": "convex dev --once",
    "convex:deploy": "convex deploy --cmd \"npm run build\" --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL",
    "vercel-build": "node scripts/vercel-build.mjs",
    "prefetch": "node scripts/fetch-sf-roads.mjs && node scripts/fetch-sf-ped-counts.mjs",
    "cache-brief": "node scripts/build-brief-cache.mjs",
    "build": "npm run prefetch && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.5",
    "@deck.gl/layers": "^9.3.5",
    "@deck.gl/mapbox": "^9.3.5",
    "@deck.gl/react": "^9.3.5",
    "@deck.gl/widgets": "^9.3.5",
    "@huggingface/transformers": "^4.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "convex": "^1.42.0",
    "mapbox-gl": "^3.9.0",
    "next": "^15.1.6",
    "orangeslice": "^2.6.0",
    "playwright": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.1.1",
    "three": "^0.185.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.3"
  }
}
